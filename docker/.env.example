# Copy to .env and fill in: cp .env.example .env && chmod 600 .env
# Never commit the real .env file.

SONAR_DB_USER=sonar
SONAR_DB_NAME=sonar
# Generate a strong password: openssl rand -base64 32 | tr -d '/+=' | head -c 40
SONAR_DB_PASSWORD=change_me

# Public domain. Must resolve to this host before Caddy can issue a certificate.
SONAR_DOMAIN=sonar.example.com
ACME_EMAIL=admin@example.com

# Pin to an exact patch release in production, for example sonarqube:2026.1.0-community
SONAR_IMAGE=sonarqube:2026-lta-community

# Optional JVM sizing overrides, see docs/sizing.md
SONAR_WEB_JAVAOPTS=
SONAR_CE_JAVAOPTS=
SONAR_SEARCH_JAVAADDITIONALOPTS=
